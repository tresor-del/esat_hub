# --- SECURITY ---
# Generate new keys using: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
REFRESH_SECRET_KEY=your_refresh_secret_key_here
DEBUG=false

# --- DATABASE ---
# Format: postgresql://user:password@localhost:5432/dbname
SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost:5432/db_name

# --- SMTP / EMAIL ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAILS_FROM_EMAIL=your_email@gmail.com
EMAILS_FROM_NAME=YourAppName
SMTP_TLS=True
SMTP_SSL=False

# --- INITIAL SUPER ADMIN ---
SUPER_ADMIN_FIRST_NAME=Admin
SUPER_ADMIN_LAST_NAME=User
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PROFIL_NAME=superadmin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change_this_password
SUPER_ADMIN_SCHOOL_NAME=YourSchool
SUPER_ADMIN_DOMAIN=Engineering
SUPER_ADMIN_MAJOR=IT
SUPER_ADMIN_LEVEL=L3
SUPER_ADMIN_YEAR=2023-2024
SUPER_ADMIN_ROLE=ADMIN
SUPER_ADMIN_STATUS=ACTIVE
SUPER_ADMIN_PHONE_NUMBER=+XXX00000000
SUPER_ADMIN_BIRTHDAY=2000-01-01
SUPER_ADMIN_CARD_NUMBER=CARD-000000

# --- CORS SETTINGS ---
# List of allowed origins separated by commas
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
